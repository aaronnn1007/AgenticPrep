# Environment Configuration for Multi-Agent Interview Analyzer
# =============================================================
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and should never be committed

# OpenAI API Configuration
# -------------------------
# Required for all LLM-based agents including Recommendation System
OPENAI_API_KEY=your-openai-api-key-here

# Model Selection (Optional - defaults provided)
# -----------------------------------------------
RECOMMENDATION_MODEL=gpt-4o-mini
QUESTION_GENERATION_MODEL=gpt-4o-mini
ANSWER_QUALITY_MODEL=gpt-4o-mini

# API Base URL (Optional - for using alternative endpoints)
# ----------------------------------------------------------
# OPENAI_BASE_URL=https://api.openai.com/v1

# Application Settings (Optional)
# --------------------------------
DEBUG=false
LOG_LEVEL=INFO

# API Server Configuration (if running backend)
# ----------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Usage Instructions
# ------------------
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your OpenAI API key
# 3. Save the file
# 4. Run your application - the .env file will be loaded automatically
#
# For Recommendation System Agent:
# - OPENAI_API_KEY is REQUIRED
# - RECOMMENDATION_MODEL is optional (defaults to gpt-4o-mini)
#
# Security Note:
# - NEVER commit your .env file to version control
# - Keep your API keys secure
# - Rotate keys if accidentally exposed
